<Window x:Class="masodfokuWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:masodfokuWPF"
        mc:Ignorable="d"
        Title="Másodfokú egyenlet" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        BorderBrush="Gray"
        BorderThickness="3">
    <StackPanel Orientation="Vertical"
                Margin="10">
        <StackPanel Orientation="Horizontal"
                    Margin="0 5">
            <Label Content="a:"
                   FontSize="15"
                   FontWeight="DemiBold"/>
            <TextBox Name="tbx_a"
                     Height="30"
                     Width="290"
                     Margin="40 0 0 0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    Margin="0 5">
            <Label Content="b:"
                   FontSize="15"
                   FontWeight="DemiBold"/>
            <TextBox Name="tbx_b"
                     Height="30"
                     Width="290"
                     Margin="38 0 0 0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    Margin="0 5">
            <Label Content="c:"
                   FontSize="15"
                   FontWeight="DemiBold"/>
            <TextBox Name="tbx_c"
                     Height="30"
                     Width="290"
                     Margin="40 0 0 0"/>
        </StackPanel>







    </StackPanel>
</Window>
